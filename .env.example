
# Generate with: bunx auth secret
AUTH_SECRET=

# Each provider below is only enabled once all of its variables are set.

# Microsoft Entra ID (Azure AD) application credentials
AUTH_ENTRAID_ID=
AUTH_ENTRAID_SECRET=
AUTH_ENTRAID_ISSUER=https://login.microsoftonline.com/<tenant-id>/v2.0

# GitHub OAuth app credentials
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Google OAuth client credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Generic OIDC provider
AUTH_OIDC_ID=
AUTH_OIDC_SECRET=
AUTH_OIDC_ISSUER=
AUTH_OIDC_NAME=

# Prisma datasource — matches the local Postgres container started by `bun dev`
DATABASE_URL="postgresql://app:password@localhost:37874/dev"
